<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="016_create_habit_daily_tasks" author="cursor">
        <preConditions onFail="CONTINUE">
            <not>
                <tableExists tableName="habit_daily_tasks"/>
            </not>
        </preConditions>

        <createTable tableName="habit_daily_tasks" remarks="Ежедневные задания трекера привычек">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="habit_tracker_entry_id" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="task_text" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="task_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="remind_evening" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_habit_daily_tasks_user_date" tableName="habit_daily_tasks">
            <column name="user_id"/>
            <column name="task_date"/>
        </createIndex>

        <addForeignKeyConstraint
                baseTableName="habit_daily_tasks"
                baseColumnNames="user_id"
                constraintName="fk_habit_daily_tasks_user_id"
                referencedTableName="users"
                referencedColumnNames="user_id"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="habit_daily_tasks"
                baseColumnNames="habit_tracker_entry_id"
                constraintName="fk_habit_daily_tasks_entry_id"
                referencedTableName="habit_tracker_entries"
                referencedColumnNames="id"
                onDelete="SET NULL"/>

        <rollback>
            <dropTable tableName="habit_daily_tasks"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
