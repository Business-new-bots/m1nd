<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="015_create_habit_tracker_entries" author="cursor">
        <preConditions onFail="CONTINUE">
            <not>
                <tableExists tableName="habit_tracker_entries"/>
            </not>
        </preConditions>

        <createTable tableName="habit_tracker_entries" remarks="Привычки пользователя для трекера привычек">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="habit_area" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="habit_name" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="duration_plan" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="frequency_plan" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_habit_tracker_entries_user_id" tableName="habit_tracker_entries">
            <column name="user_id"/>
        </createIndex>

        <addForeignKeyConstraint
                baseTableName="habit_tracker_entries"
                baseColumnNames="user_id"
                constraintName="fk_habit_tracker_entries_user_id"
                referencedTableName="users"
                referencedColumnNames="user_id"
                onDelete="CASCADE"/>

        <rollback>
            <dropTable tableName="habit_tracker_entries"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
