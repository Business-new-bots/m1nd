<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="019_add_evening_reminder_sent_at_to_habit_daily_tasks" author="cursor">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="habit_daily_tasks"/>
                <not>
                    <columnExists tableName="habit_daily_tasks" columnName="evening_reminder_sent_at"/>
                </not>
            </and>
        </preConditions>

        <addColumn tableName="habit_daily_tasks">
            <column name="evening_reminder_sent_at" type="TIMESTAMP WITH TIME ZONE"/>
        </addColumn>

        <createIndex indexName="idx_habit_daily_tasks_evening_unsent" tableName="habit_daily_tasks">
            <column name="task_date"/>
            <column name="remind_evening"/>
            <column name="evening_reminder_sent_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
