<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="014_add_assistant_type_column" author="m1nd">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="assistants"/>
            <not>
                <columnExists tableName="assistants" columnName="type"/>
            </not>
        </preConditions>

        <addColumn tableName="assistants">
            <column name="type" type="VARCHAR(20)" defaultValue="MESSAGE">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>

