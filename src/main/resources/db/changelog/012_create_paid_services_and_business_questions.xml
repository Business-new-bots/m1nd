<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog 
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Таблица ассистентов бизнеса -->
    <changeSet id="012_create_assistants" author="m1nd">
        <preConditions onFail="CONTINUE">
            <not>
                <tableExists tableName="assistants"/>
            </not>
        </preConditions>

        <createTable tableName="assistants" remarks="Ассистенты бизнеса">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="telegram_user_id" type="BIGINT">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="username" type="VARCHAR(255)"/>
            <column name="first_name" type="VARCHAR(255)"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <createIndex indexName="idx_assistants_telegram_user_id" tableName="assistants">
            <column name="telegram_user_id"/>
        </createIndex>
    </changeSet>

    <!-- Таблица платных вопросов бизнесу -->
    <changeSet id="013_create_business_questions" author="m1nd">
        <preConditions onFail="CONTINUE">
            <not>
                <tableExists tableName="business_questions"/>
            </not>
        </preConditions>

        <createTable tableName="business_questions" remarks="Платные вопросы бизнесу">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="assistant_user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="question_text" type="TEXT"/>
            <column name="answer_text" type="TEXT"/>
            <column name="status" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="answered_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <createIndex indexName="idx_business_questions_user_id" tableName="business_questions">
            <column name="user_id"/>
        </createIndex>
        <createIndex indexName="idx_business_questions_assistant_user_id" tableName="business_questions">
            <column name="assistant_user_id"/>
        </createIndex>
    </changeSet>

    <!-- Таблица платных услуг -->
    <changeSet id="014_create_paid_services" author="m1nd">
        <preConditions onFail="CONTINUE">
            <not>
                <tableExists tableName="paid_services"/>
            </not>
        </preConditions>

        <createTable tableName="paid_services" remarks="Платные услуги">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <!-- Цена в XTR, 100 = 1 звезда -->
            <column name="price_units" type="INTEGER"/>
            <column name="currency" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>

