<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog 
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="011_add_counters_to_user_progress" author="m1nd">
        <preConditions onFail="CONTINUE">
            <tableExists tableName="user_progress"/>
        </preConditions>

        <addColumn tableName="user_progress">
            <column name="facts_viewed" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="ideas_viewed" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="motivations_viewed" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="games_played" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <rollback>
            <dropColumn tableName="user_progress" columnName="facts_viewed"/>
            <dropColumn tableName="user_progress" columnName="ideas_viewed"/>
            <dropColumn tableName="user_progress" columnName="motivations_viewed"/>
            <dropColumn tableName="user_progress" columnName="games_played"/>
        </rollback>
    </changeSet>

</databaseChangeLog>

